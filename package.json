{
  "name": "aurix-network-bep20",
  "version": "1.0.0",
  "description": "AURIX Network AURX BEP-20 token deployment package for BSC Testnet/Mainnet using Hardhat 3.",
  "type": "module",
  "scripts": {
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network bscTestnet",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network bscMainnet",
    "verify:testnet": "hardhat verify --network bscTestnet",
    "verify:mainnet": "hardhat verify --network bscMainnet",
    "check:testnet": "hardhat run scripts/check.ts --network bscTestnet",
    "check:mainnet": "hardhat run scripts/check.ts --network bscMainnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.6",
    "@nomicfoundation/hardhat-ethers": "^4.0.12",
    "@nomicfoundation/hardhat-ignition": "^3.1.6",
    "@nomicfoundation/hardhat-verify": "^3.0.17",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.1",
    "@types/mocha": ">=10.0.10",
    "@types/node": "^22.8.5",
    "chai": "^6.2.2",
    "dotenv": "^17.2.3",
    "ethers": "^6.14.0",
    "forge-std": "foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.1.0",
    "mocha": "^11.0.0",
    "typescript": "~6.0.3"
  }
}